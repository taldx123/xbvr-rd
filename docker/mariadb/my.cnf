# =============================================================
#  MariaDB tuning for XBVR
# =============================================================

[mariadb]

# Allow up to 400 connections.
# XBVR uses up to 300 (DB_CONNECTION_POOL_SIZE), leaving 100
# available for external tools / administration.
max_connections            = 400

# InnoDB buffer pool – increase on machines with more RAM.
# 256 M is a safe default; try 512M or 1G if you have headroom.
innodb_buffer_pool_size    = 256M

# Recommended character set for XBVR
character-set-server       = utf8mb4
collation-server           = utf8mb4_unicode_ci
